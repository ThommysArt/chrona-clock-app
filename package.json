{
  "name": "chrona-clock-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "dev": "APP_VARIANT=development expo start --clear",
    "dev:preview": "APP_VARIANT=preview expo start --clear",
    "android": "APP_VARIANT=development expo run:android",
    "ios": "APP_VARIANT=development expo run:ios",
    "prebuild": "expo prebuild --platform android --non-interactive",
    "prebuild:dev": "APP_VARIANT=development expo prebuild --platform android --clean --non-interactive",
    "prebuild:preview": "APP_VARIANT=preview expo prebuild --platform android --clean --non-interactive",
    "prebuild:prod": "APP_VARIANT=production expo prebuild --platform android --clean --non-interactive",
    "build:dev": "APP_VARIANT=development node scripts/build-apk.mjs debug",
    "build:preview": "APP_VARIANT=preview node scripts/build-apk.mjs release",
    "build:prod": "APP_VARIANT=production node scripts/build-apk.mjs release",
    "install:dev": "node scripts/install-apk.mjs development",
    "install:preview": "node scripts/install-apk.mjs preview",
    "install:prod": "node scripts/install-apk.mjs production",
    "eas:dev": "APP_VARIANT=development eas build --platform android --profile development",
    "eas:preview": "APP_VARIANT=preview eas build --platform android --profile preview",
    "eas:prod": "APP_VARIANT=production eas build --platform android --profile production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/metro-runtime": "~57.0.2",
    "@expo/ui": "~57.0.7",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@js-temporal/polyfill": "^0.5.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@vvo/tzdb": "^6.198.0",
    "city-timezones": "^1.3.4",
    "expo": "~57.0.0",
    "expo-asset": "~57.0.3",
    "expo-blur": "^57.0.0",
    "expo-constants": "~57.0.2",
    "expo-dev-client": "~57.0.8",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-gl": "^57.0.1",
    "expo-haptics": "^57.0.0",
    "expo-linear-gradient": "^57.0.0",
    "expo-linking": "~57.0.1",
    "expo-router": "~57.0.2",
    "expo-splash-screen": "~57.0.1",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-three": "^8.0.0",
    "expo-widgets": "~57.0.6",
    "heroui-native": "^1.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-android-widget": "^0.21.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "three": "^0.185.1",
    "uniwind": "^1.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.15",
    "@types/three": "^0.185.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^57.0.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3"
  },
  "packageManager": "pnpm@10.33.2"
}
